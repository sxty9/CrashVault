# CrashVault environment — copy to .env and fill in. NEVER commit the real .env.
#
# On the Ubuntu server these are loaded two ways:
#   - systemd EnvironmentFile=.../.env  (the running service)
#   - server.js's own .env loader        (when run directly, e.g. local dev)
# Real environment variables always win over .env.

# GitHub Personal Access Token, Contents=Read+Write on the CrashVault repo.
# Same token that was set in Vercel.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repo coordinates.
GITHUB_OWNER=sxty9
GITHUB_REPO=CrashVault
GITHUB_BRANCH=main

# Session signing secret, 32+ chars. MUST be identical to the Vercel value
# so existing logins survive the cutover. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-hex-from-openssl-rand

# Port the Node process listens on (127.0.0.1 only — cloudflared proxies to it).
# 29927 = crc32("CrashVault") % 39151 + 10000 — deterministic, reproducible,
# and intentionally not 8080 (reserved for the future apex-domain main site).
PORT=29927
